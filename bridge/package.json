{
  "name": "co-mpanion-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Bridges GitHub Copilot CLI activity to a co-mpanion BLE desk-buddy device.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "co-mpanion": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "simulate": "node src/index.js --simulate",
    "dry-run": "node src/index.js --simulate --no-ble",
    "mcp": "node src/index.js --mcp",
    "mcp-stdio": "node src/index.js --mcp-stdio",
    "flash": "node src/index.js --flash",
    "test": "node test/mcp-roundtrip.js && node test/ota-flash.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-25",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.8.1"
  }
}
