    "simulate": "node src/index.js --simulate",
    "dry-run": "node src/index.js --simulate --no-ble"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-25",
    "better-sqlite3": "^11.8.1"
  }
}
